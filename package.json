{
  "name": "outlook-email-evaluator",
  "version": "1.1.0",
  "description": "Unit tests for Outlook Email Evaluator Chrome extension",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "deploy:analyze-email": "supabase functions deploy analyze-email",
    "deploy:report-feedback": "supabase functions deploy report-feedback",
    "deploy:functions": "supabase functions deploy analyze-email && supabase functions deploy report-feedback && supabase functions deploy admin-console",
    "deploy:admin-console": "supabase functions deploy admin-console",
    "admin:ui": "npx --yes serve -l 8765 ."
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "jest": "^29.0.0",
    "supabase": "^2.84.5"
  },
  "dependencies": {
    "jsqr": "^1.4.0"
  }
}
