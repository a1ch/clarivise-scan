# Prefer the repo-root copy: ../../.streamlit/secrets.toml.example
# When running streamlit_app.py from repo root, secrets belong in /.streamlit/secrets.toml
# Streamlit Cloud: paste into Settings → Secrets (not this file).
# Never commit real secrets.toml.

SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY = "eyJ... anon or publishable key (Auth: sign up / sign in)"
SUPABASE_SERVICE_ROLE_KEY = "eyJ... service_role (create keys; keep secret)"

# Optional: all portal keys are tied to this org (recommended for a single-tenant product).
# Get UUID from: select id, name from public.organizations;
DEFAULT_ORG_ID = ""

# Optional but recommended: users must type this exact string to submit (stops random signups).
PORTAL_SIGNUP_SECRET = "change-me-to-a-long-random-phrase"

# Optional: override legal links on the signup checkbox row
# TERMS_URL = "https://ingot.solutions/terms"
# PRIVACY_URL = "https://github.com/a1ch/outlook-email-evaluator/blob/main/PRIVACY.md"

# Optional: white-label portal text (see portal/app.py)
# PORTAL_PRODUCT_NAME = "Outlook Email Evaluator"
# PORTAL_BRAND_NAME = "Ingot Solutions"
# PORTAL_TAGLINE = "Hero subhead (optional)"
# PORTAL_COMPANY_URL = "https://ingot.solutions"
# PORTAL_GITHUB_URL = "https://github.com/a1ch/outlook-email-evaluator"
