# Streamlit loads secrets from THIS file when you run from the repo root:
#   copy this to .streamlit/secrets.toml  (same folder as this example)
# On Streamlit Community Cloud: paste this entire block into the app → ⚙ Settings → Secrets.

SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
# Anon (publishable) key — required for end-user sign-up / sign-in (Supabase Auth)
SUPABASE_ANON_KEY = "eyJ... paste anon or publishable key from Project Settings → API"
# Service role — required to create customers and extension tokens (keep secret; never in the browser)
SUPABASE_SERVICE_ROLE_KEY = "eyJ... paste service_role key from Supabase → Project Settings → API ..."

# Optional: UUID from  select id, name from public.organizations;
DEFAULT_ORG_ID = ""

# Optional: shared passphrase users must enter to submit
PORTAL_SIGNUP_SECRET = ""

# Optional: override links shown next to the “agree to terms” checkbox
# TERMS_URL = "https://ingot.solutions/terms"
# PRIVACY_URL = "https://github.com/a1ch/outlook-email-evaluator/blob/main/PRIVACY.md"

# Optional: white-label the portal copy (product name, brand, links on the page)
# PORTAL_PRODUCT_NAME = "Outlook Email Evaluator"
# PORTAL_BRAND_NAME = "Ingot Solutions"
# PORTAL_TAGLINE = "One sentence value prop for the hero (shown under the product name)"
# PORTAL_COMPANY_URL = "https://ingot.solutions"
# PORTAL_GITHUB_URL = "https://github.com/a1ch/outlook-email-evaluator"
